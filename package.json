{
  "name": "flue-serverless-coding-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "flue dev --target cloudflare",
    "build": "flue build --target cloudflare && node scripts/patch-flue-wrangler.mjs",
    "deploy": "npm run build && wrangler deploy --config dist/wrangler.jsonc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/shell": "^0.3.8",
    "@flue/runtime": "0.8.0-beta.6",
    "agents": "^0.13.3",
    "just-bash": "^3.0.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@flue/cli": "0.8.0-beta.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.95.0"
  }
}
