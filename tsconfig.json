{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["app.ts", "agents/**/*.ts", "connectors/**/*.ts", "lib/**/*.ts", "tests/**/*.ts", ".flue/**/*.ts"],
  "exclude": ["dist"]
}
